# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Providers
ANTHROPIC_API_KEY=your_anthropic_api_key_not_used_users_provide_their_own
GEMINI_API_KEY=your_gemini_api_key_for_free_tier_public
GEMINI_API_KEY_PRIVATE=your_gemini_api_key_for_pro_tier_private

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_character_hex_string_for_encrypting_api_keys

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Stripe Configuration (for international users - future)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id

# Razorpay Configuration (for Indian users)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PRO_PLAN_ID=plan_your_plan_id

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=your_database_connection_string

# Admin Configuration
# Comma-separated list of admin emails (fallback if database role check fails)
ADMIN_EMAILS=admin@humanify.com,your-admin@email.com

# JWT Secret (for additional auth if needed)
JWT_SECRET=your_jwt_secret_key_min_32_characters

# Environment
NODE_ENV=development

# Sentry Error Tracking (Optional)
# Get these from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# PostHog Analytics (Optional)
# Get these from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend Email Service (REQUIRED for email notifications)
# Get these from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="Humanify <noreply@yourdomain.com>"
EMAIL_REPLY_TO=support@yourdomain.com
# For testing mode (re_test_ keys), set this to your account email
RESEND_TESTING_EMAIL=your-email@example.com

# Admin Emails (comma-separated list for emergency admin access)
# Example: admin@humanify.com,yourname@example.com
ADMIN_EMAILS=admin@humanify.com